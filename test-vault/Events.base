filters:
  and:
    - file.hasTag("event")
views:
  - type: calendar
    name: Calendar
    order:
      - file.name
      - tags
      - related
      - url
    startDate: note.date
    endDate: note.endDate
    weekStartDay: monday
  - type: cards
    name: Table
    order:
      - file.name
      - date
      - endDate
      - tags
      - related
